{
  "name": "transcribly",
  "version": "1.0.1",
  "description": "CLI tool to transcribe YouTube videos and local audio/video files using OpenAI Whisper API",
  "main": "dist/index.js",
  "bin": {
    "transcribly": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "transcribe",
    "youtube",
    "whisper",
    "openai",
    "audio",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "fluent-ffmpeg": "^2.1.3",
    "openai": "^4.77.0",
    "ora": "^5.4.1",
    "yt-dlp-exec": "^1.0.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/*.test.ts"]
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3"
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
